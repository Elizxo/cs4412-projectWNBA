import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans

import pandas as pd

df = pd.read_csv("wnbadraft.csv")
display(df)
df.shape
df.info()
df.describe()

# Histogram
plt.figure(figsize=(8,4))  
df["points"].hist(bins=30)
plt.title("Distribution of Career Points")
plt.xlabel("Points")
plt.ylabel("Players")
plt.show()

# Box plot
plt.boxplot(df["win_shares"], vert=True, patch_artist=True, widths=0.5)
plt.title("Win Shares Distribution")
plt.ylabel("Win Shares")
plt.xticks([1], ["Win Shares"])  
plt.show()

# Scatter plot
plt.figure(figsize=(10,6))  
plt.scatter(df["minutes_played"], df["win_shares"])
plt.xlabel("Minutes Played")
plt.ylabel("Win Shares")
plt.title("Minutes vs Win Shares")
plt.show()

# Correlation heatmap
plt.figure(figsize=(10,8))
corr = df.corr(numeric_only=True)
sns.heatmap(corr, annot=True, cmap="coolwarm")
plt.title("Correlation Matrix")
plt.show()


#Cleaning data 
df.isna().sum()
df = df.dropna()
df.duplicated().sum()
df = df.drop_duplicates()


df = df[df["minutes_played"] > 0]

df["impact_per_minute"] = df["win_shares"] / df["minutes_played"]


top_efficiency = df.sort_values(by="impact_per_minute", ascending=False)

top_efficiency[["player","team","minutes_played","win_shares","impact_per_minute"]].head(15)


volume_players = df.sort_values(by="minutes_played", ascending=False)

volume_players[["player","minutes_played","win_shares","points"]].head(15)


features = ["minutes_played","points","assists","total_rebounds","win_shares"]

X = df[features]

scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

sse = []

for k in range(1,11):
    km = KMeans(n_clusters=k, init='k-means++', n_init=10, random_state=42)
    km.fit(X_scaled)
    sse.append(km.inertia_)

plt.plot(range(1,11), sse, marker='o')
plt.xlabel("Number of Clusters (k)")
plt.ylabel("SSE")
plt.title("Elbow Method")
plt.show()

kmeans = KMeans(
    n_clusters=3,
    init='k-means++',
    n_init=10,
    random_state=42
)

df["cluster"] = kmeans.fit_predict(X_scaled)

df[df["cluster"] == 1][["player","points","minutes_played","win_shares"]].head(20)


plt.scatter(df["minutes_played"], df["win_shares"], c=df["cluster"])
plt.xlabel("Minutes Played")
plt.ylabel("Win Shares")
plt.title("Player Career Clusters")
plt.show()

df.groupby("cluster")[[
    "games",
    "years_played",
    "win_shares",
    "points",
    "minutes_played"
]].mean()
